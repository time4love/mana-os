# Mana Skills contract (from Foundry deploy). Use 0x0... when not deployed.
NEXT_PUBLIC_MANA_SKILLS_ADDRESS=0x0000000000000000000000000000000000000000

# Architect's Key: wallet address that bypasses SBT locks for local UI testing (Truth Engine, Resonance, Sieve).
# Set to your MetaMask/Rabby dev wallet to unlock all gates without holding an SBT.
NEXT_PUBLIC_ARCHITECT_WALLET=0xYourTestWalletAddressHere

# Optional: set to "true" to bypass SBT check for any connected wallet (less secure; prefer ARCHITECT_WALLET).
# NEXT_PUBLIC_TRUTH_SBT_BYPASS=false

# Proposals DAO (Resonance governance). Deploy after ManaSkills; set MANA_SKILLS_ADDRESS in .env when running script.
NEXT_PUBLIC_PROPOSALS_DAO_ADDRESS=0x...

# Optional: match your local node (Foundry Anvil / Hardhat)
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Supabase (onboarding / Soul Contract profiles). Anon key only; no service role needed.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# AI Oracle (Phase 4) — Socratic Oracle, embeddings
OPENAI_API_KEY=sk-...

# Truth Engine / Epistemic Prism — Gemini 1.5 Pro (large context, anti–appeal-to-authority analysis)
# Get your key from https://aistudio.google.com/apikey and add to .env.local
GOOGLE_GENERATIVE_AI_API_KEY=
